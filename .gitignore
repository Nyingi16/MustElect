# ============================================
*.bak
*.old
*.orig
*.rej
*.save
*.backup
.DS_Store
.directory
.ftpconfig
.remote-sync.json
.vscode/settings.json

# ============================================
# Application Specific
# ============================================
# Ganache generated files
ganache-*.db
ganache-*.log

# Truffle generated files
truffle-config.js.bak
truffle-config.js.old

# Sequelize generated files
.sequelizerc.backup
seeders/development/
seeders/production/

# Reports directory (keep structure but ignore contents)
reports/*
!reports/.gitkeep

# Backups directory (keep structure but ignore contents)
backend/backups/*
!backend/backups/.gitkeep

# Uploads directory (keep structure but ignore contents)
backend/uploads/*
!backend/uploads/.gitkeep

# ============================================
# Dependency directories
# ============================================
jspm_packages/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env.vault

# parcel-bundler cache
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing
.vscode-test

# Temporary folders
tmp/
temp/