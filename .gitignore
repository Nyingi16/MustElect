# ============================================
reports/*.pdf
reports/*.csv
reports/*.xlsx
reports/*.html
*.generated.js
*.generated.css
*.generated.scss

# ============================================
# User-specific files
# ============================================
*.user
*.userosscache
*.sln.docstates
*.suo
*.cachefile
*.vcxproj.user

# ============================================
