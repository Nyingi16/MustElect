# ============================================
# MUST Elections System - .gitignore
# ============================================

# ============================================
# Node.js / JavaScript
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
.env.backup
.env.example
*.env

# ============================================
# Backend Specific
# ============================================
backend/node_modules/
backend/.env
backend/.env.local
backend/config/config.json
backend/config/config.local.json
backend/logs/
backend/*.log
backend/reports/*.pdf
backend/reports/*.csv
backend/reports/*.xlsx
backend/backups/
backend/uploads/
backend/temp/
backend/.cache

# ============================================
# Frontend Specific
# ============================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.production
frontend/.env.development
frontend/.cache
frontend/.vercel
frontend/.next/trace
frontend/.next/cache
frontend/public/uploads/
frontend/public/temp/

# ============================================
# Blockchain / Truffle / Ganache
# ============================================
build/contracts/
build/contracts/*.json
build/contracts/*.bin
contracts/backup/
migrations/backup/
